{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["nodejs"],
      "phases": {
        "setup": {
          "nixpacksPkgs": ["nodejs_20", "mysql80"]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "mysql -h $DB_HOST -u $DB_USER -p$DB_PASSWORD $DB_NAME < fof-backend/db/schema.sql && node server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
