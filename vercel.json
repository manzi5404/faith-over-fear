{
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/admin$",
      "dest": "/admin/index.html"
    },
    {
      "src": "^/admin/(.*)",
      "dest": "/admin/$1"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/([^\\.]+)$",
      "dest": "/$1.html"
    }
  ]
}