{
  "version": 2,
  "name": "faithoverfearrw",
  "builds": [
    {
      "src": "dist/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://fof-backend-xxxx.up.railway.app/api/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/dist/admin/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ]
}