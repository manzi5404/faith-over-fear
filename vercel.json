{
  "version": 3,
  "name": "faithoverfearrw",
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://YOUR-BACKEND-URL.railway.app/api/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/dist/admin/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    }
  ]
}