# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=3000
NODE_ENV=production

# Admin email addresses (comma-separated) — users with these emails
# automatically receive the "admin" role during registration and Google OAuth.
# Case-insensitive, whitespace is trimmed.
ADMIN_EMAILS=admin@dottieyz.rw,manager@test.com

# CORS Allowed Origins
ALLOWED_ORIGINS=https://dottieyzrw.netlify.app,http://localhost:3000

